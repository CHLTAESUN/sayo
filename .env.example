# Supabase 연결 설정. 실제 값은 .env 에 넣으세요(.env 는 git에 올라가지 않음).
# Supabase 대시보드 → Settings → Data API 에서 Project URL,
# Settings → API Keys 에서 게시 가능한(publishable) 키를 복사.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Cloudflare Turnstile(봇 차단 캡차) 사이트 키(공개). Cloudflare → Turnstile 위젯에서 복사.
# 없으면 캡차 자동 비활성. Secret 키는 코드에 두지 말고 Supabase Attack Protection에만.
VITE_TURNSTILE_SITE_KEY=0x4AAAA_your_site_key
